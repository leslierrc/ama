# ── PayPal ────────────────────────────────────────────────
# Obtén tus credenciales en https://developer.paypal.com/dashboard/
# Para producción usa: https://www.paypal.com/signin (live credentials)
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here

# ── Supabase ───────────────────────────────────────────────
# Obtén estos valores en https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── WhatsApp ───────────────────────────────────────────────
# Número en formato internacional sin espacios ni signos
VITE_WHATSAPP_NUMBER=5355542936

# ── Admin ─────────────────────────────────────────────────
# Email del administrador registrado en Supabase Auth
VITE_ADMIN_EMAIL=admin@amastore.cu
